# === Transient / session data (large, changes every session) ===
debug/
todos/
session-env/
file-history/
paste-cache/
telemetry/
shell-snapshots/
cache/
stats-cache.json
mcp-needs-auth-cache.json
history.jsonl

# Plans and tasks are session artifacts
plans/
tasks/

# Plugin caches and cloned repos (reproducible from settings.json enabledPlugins)
plugins/cache/
plugins/repos/
plugins/marketplaces/
plugins/install-counts-cache.json
plugins/installed_plugins.json
plugins/known_marketplaces.json

# macOS junk
.DS_Store

# Python bytecode
__pycache__/

# Cached images
image-cache/

# IDE metadata
ide/

# Chrome browser automation state
chrome/

# Session transcripts (per-project, contain conversation data)
projects/

# Downloads
downloads/

# Usage data
usage-data/

# Logs
logs/

# Statsig feature flag cache (runtime)
statsig/

# Auto-memory (per-project, auto-generated)
.claude/

# Bin (if auto-generated)
bin/

# Old pre-git backups (git handles versioning now)
backups/

# === Personal files (per-user, not shared) ===

# Personal overrides (see rules/personal.md.example)
rules/personal.md

# Memory is per-user
memory/journal.md
memory/lessons.md
memory/*.md
!memory/.gitkeep

# Local settings override
settings.local.json

# Personal schedules
schedules.json

# Personal PM/voice skills (symlinked from ~/Code/pm_os)
skills/pm-*
skills/yk-voice.md
